// OpenClaw Config Template — Source of Truth
// Generated per-agent by: ./configs/generate-config.sh <agent>
// Do NOT edit individual openclaw.json files directly.
// Version: 2026-02-23
{
  // === Meta (auto-managed by OpenClaw) ===
  "meta": {
    "lastTouchedVersion": "2026.2.21-2"
  },

  // === Browser ===
  "browser": {
    "headless": false,
    "defaultProfile": "openclaw"
  },

  // === UI ===
  "ui": {
    "seamColor": "#FF6B35",
    "assistant": {
      "name": "${AGENT_NAME} ${AGENT_EMOJI}",
      "avatar": "${AGENT_EMOJI}"
    }
  },

  // === Auth ===
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "api_key"
      }
    }
  },

  // === Gateway ===
  "gateway": {
    "port": 18799,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },

  // === Agent Identity (per-agent) ===
  "agents": {
    "defaults": {
      "model": {
        "primary": "${AGENT_MODEL}"
      },
      "models": {
        "anthropic/claude-sonnet-4-6": {},
        "anthropic/claude-opus-4-6": {}
      },
      "workspace": "${AGENT_WORKSPACE}",

      // === Compaction (safeguard + memory flush) ===
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 24000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 6000,
          "systemPrompt": "Session nearing compaction. Store durable memories now.",
          "prompt": "Before compaction, save important context, decisions, and pending work to memory/YYYY-MM-DD.md. Include enough detail that future-you can pick up where you left off. Reply with NO_REPLY if nothing to store."
        }
      },

      // === Context Pruning (cache-aware tool trimming) ===
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m",
        "keepLastAssistants": 3,
        "hardClear": { "enabled": true },
        "tools": { "deny": ["browser", "canvas"] }
      },

      // === Heartbeat ===
      "heartbeat": {
        "every": "30m",
        "model": "anthropic/claude-haiku-4-5",
        "target": "none",
        "suppressToolErrorWarnings": true
      }
    },
    "list": [
      {
        "id": "${AGENT_ID}",
        "default": true,
        "name": "${AGENT_NAME}",
        "workspace": "${AGENT_WORKSPACE}",
        "model": {
          "primary": "${AGENT_MODEL}",
          "fallbacks": ["AGENT_FALLBACKS_PLACEHOLDER"]
        },
        "identity": {
          "name": "${AGENT_DISPLAY_NAME}",
          "emoji": "${AGENT_EMOJI}"
        }
      }
    ]
  },

  // === Messages ===
  "messages": {
    "responsePrefix": "auto"
  },

  // === Commands ===
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },

  // === Channels ===
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "groupAllowFrom": ["*"],
      "groupPolicy": "open",
      "streaming": false
    },
    "slack": {
      "mode": "socket",
      "webhookPath": "/slack/events",
      "enabled": true,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "userToken": "${SLACK_USER_TOKEN}",
      "userTokenReadOnly": false,
      "groupPolicy": "open",
      "replyToMode": "off",
      "channels": {
        "C0AGBFKNAMB": {
          "requireMention": false,
          "allowBots": true
        }
      }
    }
  },

  // === Plugins ===
  "plugins": {
    "entries": {
      "telegram": { "enabled": true },
      "slack": { "enabled": true }
    }
  },

  // === Tools ===
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "apiKey": "${BRAVE_API_KEY}"
      },
      "fetch": {
        "enabled": true
      }
    }
  },

  // === Skills ===
  "skills": {
    "entries": {
      "nano-banana-pro": {
        "apiKey": "${GOOGLE_API_KEY}"
      },
      "openai-image-gen": {
        "apiKey": "${OPENAI_API_KEY}"
      },
      "openai-whisper-api": {
        "apiKey": "${OPENAI_API_KEY}"
      },
      "sag": {
        "apiKey": "${ELEVENLABS_API_KEY}"
      }
    }
  }
}
